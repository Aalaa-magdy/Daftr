{
  "expo": {
    "name": "Daftr",
    "slug": "Daftr",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "daftr",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daftr"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
    "package": "com.daftr"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#F7FAF8",
          "dark": {
            "backgroundColor": "#F7FAF8"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
